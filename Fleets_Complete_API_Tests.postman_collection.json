	"item": [
		{
			"name": "User Module",
			"item": [
				{
					"name": "1.1 User Registration",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response has id\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.id).to.exist;",
									"    pm.collectionVariables.set(\"userId\", jsonData.id);",
									"    pm.collectionVariables.set(\"username\", jsonData.username);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"testuser{{$timestamp}}\",\n  \"password\": \"Test123456\",\n  \"phone\": \"138{{$timestamp}}\",\n  \"email\": \"test{{$timestamp}}@example.com\",\n  \"nickname\": \"测试用户\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/user/register",
							"host": ["{{base_url}}"],
							"path": ["api", "user", "register"]
						}
					}
				}
,
